# ==============================================================================
# ocr_agentic_engine env — copy to ocr_agentic_engine/.env and fill in.
# Loaded when running: uv run uvicorn ocr_agentic_engine.app:app --port 8001 --reload
# ==============================================================================

# --- REQUIRED ---------------------------------------------------------------

# Supabase JWT HS256 secret used to verify Bearer tokens on /engine/*.
# Where to find it: Supabase Dashboard → Project Settings → API → "JWT Secret"
# (NOT the anon/service_role key). Must match the project that issues frontend tokens.
SUPABASE_JWT_SECRET=

# --- OLLAMA ----------------------------------------------------------------

# Base URL of your Ollama server. Default assumes `ollama serve` on localhost.
OLLAMA_HOST=http://localhost:11434

# Optional JSON dict overriding per-feature model picks from agents/models.yaml.
# Example: {"classification":"llama3.2:3b","comparison":"qwen2.5:7b"}
# Leave blank to use defaults.
ENGINE_MODELS_JSON=

# --- FILESYSTEM ROOTS ------------------------------------------------------

# Per-run scratch dir (uploads + intermediate artifacts). Auto-created.
ENGINE_TMP_ROOT=/tmp/engine-tmp

# Where rendered DOCX/PDF outputs live until swept. Served via GET /engine/downloads/*.
ENGINE_DOWNLOADS_ROOT=/tmp/engine-downloads

# How long generated downloads stick around before sweep.py deletes them.
ENGINE_DOWNLOAD_TTL_HOURS=24

# --- OCR CACHE -------------------------------------------------------------

# 1 = cache OCR output by sha256(input bytes); 0 = always re-run OCR.
ENGINE_OCR_CACHE=1

# Where the cache lives on disk.
ENGINE_OCR_CACHE_DIR=ocr_agentic_engine/.ocr_cache

# --- CORS ------------------------------------------------------------------

# Comma-separated origins allowed to hit the engine. Add your prod frontend URL here.
ENGINE_CORS_ORIGINS=http://localhost:3000
